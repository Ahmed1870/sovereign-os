# ══════════════════════════════════════════════════════════════════
# Sovereign OS - Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ══════════════════════════════════════════════════════════════════

# App
APP_NAME="Sovereign OS"
ENVIRONMENT=development
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
DEBUG=false
ENABLE_METRICS=true

# CORS - Update with your actual Vercel URL
ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# ── Supabase (Required) ──────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Encryption (Required) ────────────────────────────────────────
# Generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# ── External APIs (Optional - free tiers) ───────────────────────
# HaveIBeenPwned: https://haveibeenpwned.com/API/Key ($3.50/month or free for personal)
HAVEIBEENPWNED_API_KEY=

# AbstractAPI Phone Validation (250 free/month): https://app.abstractapi.com/
ABSTRACT_API_KEY=

# OpenRouter (free LLM tier): https://openrouter.ai/
OPENROUTER_API_KEY=

# Hunter.io (50 free/month): https://hunter.io/
HUNTER_IO_API_KEY=

# ── Redis (Optional - for production rate limiting) ──────────────
REDIS_URL=redis://localhost:6379

# ── Email (Optional - for sending GDPR requests) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=privacy@sovereignos.app

# ── Stripe (Future - not needed for free tier) ───────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
